        <Param val="psychoJS.eventManager.clearEvents();&amp;#10;if ((lang === &quot;ESP&quot;)) {&amp;#10;    currText = (&quot;TEXT_ESP/&quot; + textFilename);&amp;#10;} else {&amp;#10;    if ((lang === &quot;DE&quot;)) {&amp;#10;        currText = (&quot;TEXT_DE/&quot; + textFilename);&amp;#10;    } else {&amp;#10;        if ((lang === &quot;NL&quot;)) {&amp;#10;            currText = (&quot;TEXT_NL/&quot; + textFilename);&amp;#10;        } else {&amp;#10;            currText = (&quot;TEXT_ENG/&quot; + textFilename);&amp;#10;        }&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="# Reset mouse to record new clicks&amp;#10;event.clearEvents()&amp;#10;&amp;#10;# Select language&amp;#10;if lang == 'ESP':&amp;#10;    currText = 'TEXT_ESP/' + textFilename&amp;#10;elif lang == 'DE':&amp;#10;    currText = 'TEXT_DE/' + textFilename&amp;#10;elif lang == 'NL':&amp;#10;    currText = 'TEXT_NL/' + textFilename&amp;#10;else:&amp;#10;    currText = 'TEXT_ENG/' + textFilename" valType="extendedCode" updates="constant" name="Begin Routine"/>
